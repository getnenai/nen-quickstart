## Error Handling

All failures raise exceptions. `success` and `error` in the run webhook are provided by the framework automatically — they are **not** fields in `Result`.

### Raise for all failures

```python
# ✅ CORRECT — raise for failures
if not agent.verify("Is the page loaded?", timeout=20):
    raise RuntimeError("Page failed to load")

if agent.verify("Is there an error message?"):
    raise RuntimeError("Login failed — error message displayed")

data = agent.extract("Extract the order ID", Result.model_json_schema())
if not data.get("order_id"):
    raise ValueError("No order ID found on the page")
```

### Catch only for recovery (retry or alternative path)

```python
# Pattern 1: Alternative path
def run(params: Params) -> Result:
    agent = Agent()
    try:
        agent.execute("Click the blue submit button")
    except WorkflowError:
        agent.execute("Click any submit button")  # fallback

    if not agent.verify("Is there a success message?", timeout=10):
        raise RuntimeError("Submission failed")
    return Result()
```

```python
# Pattern 2: Retry
def run(params: Params) -> Result:
    agent = Agent()
    for attempt in range(3):
        try:
            agent.execute("Click Submit")
            break
        except WorkflowError:
            if attempt == 2:
                raise
            agent.execute("Scroll down to find the Submit button")
```

```python
# Pattern 3: Partial success — continue on per-item failures, raise if nothing succeeded
def run(params: Params) -> Result:
    agent = Agent()
    results = []

    for item in params.items:
        try:
            data = process_item(agent, item)
            results.append({"item": item, "data": data})
        except Exception as e:
            results.append({"item": item, "error": str(e)})
            continue

    if not any(r.get("data") for r in results):
        raise RuntimeError("All items failed — no data extracted")

    return Result(results=results)
```

