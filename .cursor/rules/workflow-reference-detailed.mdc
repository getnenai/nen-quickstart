## Workflow Structure

### Basic Template

```python
"""
Workflow: [Name]

Description of what this workflow does.
"""
from nen import Agent, Computer
from pydantic import BaseModel, Field


class Params(BaseModel):
    """Input parameters — validated before run() is called."""
    website_url: str = Field(default="https://example.com", min_length=1)


class Result(BaseModel):
    """Output schema — validated before returning to caller."""
    title: str = Field(min_length=1, description="Page title extracted from the site")


def run(params: Params) -> Result:
    """
    Main workflow entry point.

    Args:
        params: Validated Pydantic input parameters

    Returns:
        Result model with workflow output data
    """
    agent = Agent()
    computer = Computer()

    # Workflow logic
    agent.execute("Do something")

    data = agent.extract("What is the page title?", Result.model_json_schema())
    return Result.model_construct(**data)
```

### Template with Secrets

```python
"""
Workflow: [Name]

Description of what this workflow does.
"""
from nen import Agent, Computer, Secure
from pydantic import BaseModel, Field


class Params(BaseModel):
    login_url: str = Field(min_length=1)
    username: str = Field(min_length=1)


class SecureParams(BaseModel):
    password: Secure[str] = Field(min_length=1)


class Result(BaseModel):
    account_name: str = Field(min_length=1, description="Account name shown after login")


def run(params: Params, secure_params: SecureParams) -> Result:
    agent = Agent()
    computer = Computer()

    # Use params.username and secure_params.password
    data = agent.extract("What is the account name shown?", Result.model_json_schema())
    return Result.model_construct(**data)
```

### Params Access

```python
# Access as typed attributes
url = params.website_url
count = params.max_items
name = params.patient_name

# Pydantic validation happens before run() is called
# No need to check for missing or invalid params
```

### Result Structure

```python
# Return extracted data
data = agent.extract("Get article info", Result.model_json_schema())
return Result.model_construct(**data)

# Return constructed result
return Result(field_one=value_one, field_two=value_two)

# Raise for all failures — success/error are framework-provided
if not agent.verify("Is the page loaded?"):
    raise RuntimeError("Page failed to load")
```

