## Common Patterns

### Browser Automation

```python
def run(params: Params) -> Result:
    agent = Agent()
    computer = Computer()

    # Open and navigate
    agent.execute("Click the Chromium browser icon in the taskbar")
    if not agent.verify("Is the Chromium browser open?", timeout=10):
        raise RuntimeError("Failed to open Chromium browser")

    agent.execute(f"Navigate to {params.url}")
    if not agent.verify("Is the page loaded?", timeout=20):
        raise RuntimeError(f"Failed to load {params.url}")

    # Continue workflow...
    data = agent.extract("Extract relevant data", Result.model_json_schema())
    return Result.model_construct(**data)
```

### Form Filling

```python
def run(params: Params) -> Result:
    agent = Agent()
    computer = Computer()

    agent.execute("Navigate to contact form")
    if not agent.verify("Is the form visible?"):
        raise RuntimeError("Form not found")

    # Fill and clear fields
    agent.execute("Click the name field")
    computer.hotkey("ctrl", "a")
    computer.press("BackSpace")
    computer.type(params.name)

    agent.execute("Click the email field")
    computer.hotkey("ctrl", "a")
    computer.press("BackSpace")
    computer.type(params.email)

    agent.execute("Click submit button")

    if not agent.verify("Is there a success message?", timeout=10):
        raise RuntimeError("Submission failed — no success message found")

    return Result()
```

### Data Extraction

```python
def run(params: Params) -> Result:
    agent = Agent()

    agent.execute("Navigate to data page")
    if not agent.verify("Is the data table visible?"):
        raise RuntimeError("Data table not found")

    data = agent.extract(
        "Extract all rows from the table",
        Result.model_json_schema()
    )

    return Result.model_construct(**data)
```

### Login Workflow

```python
def run(params: Params, secure_params: SecureParams) -> Result:
    agent = Agent()
    computer = Computer()

    agent.execute(f"Navigate to {params.login_url}")
    if not agent.verify("Is login form visible?"):
        raise RuntimeError("Login page not found or failed to load")

    agent.execute("Click username field")
    computer.hotkey("ctrl", "a")
    computer.press("BackSpace")
    computer.type(params.username)

    agent.execute("Click password field")
    computer.hotkey("ctrl", "a")
    computer.press("BackSpace")
    computer.type(secure_params.password, interval=0.01)

    computer.press("Return")

    if agent.verify("Is there an error message?"):
        raise RuntimeError("Login failed — invalid credentials")
    if not agent.verify("Is dashboard visible?", timeout=20):
        raise RuntimeError("Login failed — dashboard not visible")

    data = agent.extract("Extract account info", Result.model_json_schema())
    return Result.model_construct(**data)
```

### Multi-Step with Checkpoints

```python
import logging

def run(params: Params) -> Result:
    agent = Agent()
    computer = Computer()

    logging.info("Step 1: Opening browser")
    agent.execute("Click the Chromium browser icon in the taskbar")
    if not agent.verify("Is the Chromium browser open?", timeout=10):
        raise RuntimeError("Failed to open Chromium browser")

    logging.info("Step 2: Authenticating")
    authenticate(agent, computer, params)  # raises on failure

    logging.info("Step 3: Extracting data")
    data = extract_data(agent)  # raises on failure

    logging.info("Workflow completed")
    return Result.model_construct(**data)
```

